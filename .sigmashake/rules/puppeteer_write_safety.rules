# puppeteer_write_safety.rules
# Technology: puppeteer | Capability: write

rule puppeteer-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_puppeteer_PATTERN"
  MESSAGE "Blocked an unsafe pattern in puppeteer. Use the recommended best practices for 2025/2026."
}

rule puppeteer-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_puppeteer_API"
  MESSAGE "You are using an outdated API for puppeteer. Please upgrade to the newer API."
}
